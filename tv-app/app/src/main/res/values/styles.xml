<resources>
    <style name="AppTheme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_dark</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="TextTitle">
        <item name="android:textSize">40sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextSubtitle">
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="NavItem">
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAlignment">center</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">25dp</item>
        <item name="android:background">@drawable/nav_item_bg</item>
    </style>

    <style name="NavItemActive">
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAlignment">center</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">25dp</item>
        <item name="android:background">@drawable/nav_item_active</item>
    </style>

    <style name="CodeDigit">
        <item name="android:textSize">56sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAlignment">center</item>
        <item name="android:gravity">center</item>
        <item name="android:width">100dp</item>
        <item name="android:height">120dp</item>
        <item name="android:background">@drawable/code_digit_normal</item>
    </style>

    <style name="KeyboardKey">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAlignment">center</item>
        <item name="android:gravity">center</item>
        <item name="android:width">85dp</item>
        <item name="android:height">65dp</item>
        <item name="android:background">@drawable/keyboard_key</item>
    </style>

    <style name="KeyboardKeyWide">
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAlignment">center</item>
        <item name="android:gravity">center</item>
        <item name="android:width">135dp</item>
        <item name="android:height">65dp</item>
        <item name="android:background">@drawable/keyboard_key</item>
    </style>

    <style name="PushCard">
        <item name="android:padding">40dp</item>
        <item name="android:background">@drawable/push_card_bg</item>
        <item name="android:layout_width">550dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="AppItem">
        <item name="android:padding">30dp</item>
        <item name="android:background">@drawable/app_item_bg</item>
        <item name="android:layout_width">280dp</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="ButtonPrimary">
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:width">300dp</item>
        <item name="android:height">60dp</item>
        <item name="android:background">@drawable/btn_primary</item>
    </style>

    <style name="ButtonSecondary">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:gravity">center</item>
        <item name="android:width">300dp</item>
        <item name="android:height">60dp</item>
        <item name="android:background">@drawable/btn_secondary</item>
    </style>
</resources>
